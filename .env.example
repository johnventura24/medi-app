# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI Analyst (Prism AI chat)
ANTHROPIC_API_KEY=sk-ant-...

# AI Plan Explainer (optional, for plan summaries)
OPENAI_API_KEY=sk-...

# Security (REQUIRED in production)
JWT_SECRET=generate-a-strong-256-bit-secret
ENCRYPTION_KEY=generate-a-64-char-hex-string
CORS_ORIGIN=https://your-domain.com

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_AGENT=price_...
STRIPE_PRICE_TEAM=price_...

# Environment
NODE_ENV=production

# Analytics (Google Analytics 4)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxx
FROM_EMAIL=noreply@prismmed.io
